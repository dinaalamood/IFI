class DecoderBlock(nn.Module):
    """U-Net decoder block with adaptive spatial matching"""
    def __init__(self, in_channels, skip_channels, out_channels):
        super().__init__()
        self.conv1 = nn.Conv2d(in_channels + skip_channels, out_channels, 3, padding=1)
        self.bn1 = nn.BatchNorm2d(out_channels)
        self.conv2 = nn.Conv2d(out_channels, out_channels, 3, padding=1)
        self.bn2 = nn.BatchNorm2d(out_channels)
        self.relu = nn.ReLU(inplace=True)
        
    def forward(self, x, skip=None):
        x = nn.functional.interpolate(x, scale_factor=2, mode='bilinear', align_corners=True)
        
        if skip is not None:
            if x.shape[2:] != skip.shape[2:]:
                skip = nn.functional.interpolate(skip, size=x.shape[2:], mode='bilinear', align_corners=True)
            x = torch.cat([x, skip], dim=1)
            
        x = self.relu(self.bn1(self.conv1(x)))
        x = self.relu(self.bn2(self.conv2(x)))
        return x

class SwinFeatureExtractor(nn.Module):
    """Wrapper to extract multi-scale features from Swin Transformer"""
    def __init__(self, swin_model):
        super().__init__()
        self.patch_embed = swin_model.patch_embed
        self.layers = swin_model.layers
        
        if hasattr(swin_model, 'pos_drop'):
            self.pos_drop = swin_model.pos_drop
        else:
            self.pos_drop = nn.Identity()
            
        if hasattr(swin_model, 'norm'):
            self.norm = swin_model.norm
        else:
            self.norm = nn.Identity()
        
    def forward(self, x):
        """Extract features from each stage"""
        features = []
        
        x = self.patch_embed(x)
        if hasattr(self, 'pos_drop'):
            x = self.pos_drop(x)
        
        for i, layer in enumerate(self.layers):
            x = layer(x)
            
            if len(x.shape) == 4:
                feature = x.permute(0, 3, 1, 2).contiguous()
            else:
                B, L, C = x.shape
                H = W = int(L ** 0.5)
                feature = x.view(B, H, W, C).permute(0, 3, 1, 2).contiguous()
            
            features.append(feature)
        
        return features

class SwinUNet(nn.Module):
    """U-Net with Swin Transformer encoder and custom decoder"""
    def __init__(self, encoder_name='swin_base_patch4_window7_224', 
                 encoder_channels=[128, 256, 512, 1024], num_classes=1):
        super().__init__()
        
        import timm
        
        # Create full Swin Transformer model
        full_model = timm.create_model(
            encoder_name,
            pretrained=False,
            num_classes=0
        )
        
        # Create feature extractor
        self.encoder = SwinFeatureExtractor(full_model)
        
        # Build decoder
        self.decoder4 = DecoderBlock(encoder_channels[3], encoder_channels[2], 512)
        self.decoder3 = DecoderBlock(512, encoder_channels[1], 256)
        self.decoder2 = DecoderBlock(256, encoder_channels[0], 128)
        self.decoder1 = DecoderBlock(128, 0, 64)
        
        # Final segmentation head
        self.segmentation_head = nn.Sequential(
            nn.Conv2d(64, 32, 3, padding=1),
            nn.BatchNorm2d(32),
            nn.ReLU(inplace=True),
            nn.Conv2d(32, num_classes, 1)
        )
    
    def forward(self, x):
        input_size = x.shape[2:]
        
        encoder_features = self.encoder(x)
        
        d4 = self.decoder4(encoder_features[3], encoder_features[2])
        d3 = self.decoder3(d4, encoder_features[1])
        d2 = self.decoder2(d3, encoder_features[0])
        d1 = self.decoder1(d2)
        
        d1 = nn.functional.interpolate(d1, size=input_size, mode='bilinear', align_corners=True)
        
        out = self.segmentation_head(d1)
        
        return out

class ImprovedSolarDataset:
    def __init__(self, image_paths, mask_paths, transform=None):
        self.image_paths = image_paths
        self.mask_paths = mask_paths
        self.transform = transform
    
    def __len__(self):
        return len(self.image_paths)
    
    def __getitem__(self, idx):
        # Read original image for visualization
        original_image = cv2.imread(self.image_paths[idx])
        original_image = cv2.cvtColor(original_image, cv2.COLOR_BGR2RGB)
        
        # Read image for model
        image = original_image.copy()
        
        mask = cv2.imread(self.mask_paths[idx], cv2.IMREAD_GRAYSCALE)
        mask = (mask > 127).astype(np.float32)
        
        if self.transform:
            augmented = self.transform(image=image, mask=mask)
            image = augmented['image']
            mask = augmented['mask']
        
        if len(mask.shape) == 2:
            mask = mask.unsqueeze(0)
        
        return image, mask, self.image_paths[idx], original_image

def get_test_augmentation(input_size):
    """Test augmentation - only resize and normalize"""
    return A.Compose([
        A.Resize(input_size, input_size),
        A.Normalize(mean=(0.485, 0.456, 0.406), std=(0.229, 0.224, 0.225)),
        ToTensorV2(),
    ])

def dice_coefficient(pred, target, threshold=0.5):
    """Calculate Dice coefficient"""
    pred = torch.sigmoid(pred)
    pred = (pred > threshold).float()
    target = target.float()
    
    intersection = (pred * target).sum()
    union = pred.sum() + target.sum()
    
    dice = (2. * intersection) / (union + 1e-8)
    return dice.item()

def iou_score(pred, target, threshold=0.5):
    """Calculate IoU score"""
    pred = torch.sigmoid(pred)
    pred = (pred > threshold).float()
    target = target.float()
    
    intersection = (pred * target).sum()
    union = pred.sum() + target.sum() - intersection
    
    iou = intersection / (union + 1e-8)
    return iou.item()

def pixel_accuracy(pred, target, threshold=0.5):
    """Calculate pixel accuracy"""
    pred = torch.sigmoid(pred)
    pred = (pred > threshold).float()
    target = target.float()
    
    correct = (pred == target).float().sum()
    total = target.numel()
    
    return (correct / total).item()

def create_overlay_visualization(original_image, ground_truth, prediction, alpha=0.5):
    """Create visualization with original image, ground truth, and prediction overlay"""
    # Resize masks to match original image size
    h, w = original_image.shape[:2]
    ground_truth_resized = cv2.resize(ground_truth, (w, h), interpolation=cv2.INTER_NEAREST)
    prediction_resized = cv2.resize(prediction, (w, h), interpolation=cv2.INTER_NEAREST)
    
    # Create colored overlays
    # Ground truth: green
    gt_overlay = original_image.copy()
    gt_mask_color = np.zeros_like(original_image)
    gt_mask_color[ground_truth_resized > 0.5] = [0, 255, 0]  # Green
    gt_overlay = cv2.addWeighted(gt_overlay, 1-alpha, gt_mask_color, alpha, 0)
    
    # Prediction: blue
    pred_overlay = original_image.copy()
    pred_mask_color = np.zeros_like(original_image)
    pred_mask_color[prediction_resized > 0.5] = [0, 0, 255]  # Blue
    pred_overlay = cv2.addWeighted(pred_overlay, 1-alpha, pred_mask_color, alpha, 0)
    
    # Combined: green for GT, blue for pred, yellow for overlap
    combined_overlay = original_image.copy()
    combined_mask_color = np.zeros_like(original_image)
    
    # True positives (overlap): yellow
    overlap = (ground_truth_resized > 0.5) & (prediction_resized > 0.5)
    combined_mask_color[overlap] = [255, 255, 0]  # Yellow
    
    # False positives (pred only): red
    fp = (ground_truth_resized <= 0.5) & (prediction_resized > 0.5)
    combined_mask_color[fp] = [255, 0, 0]  # Red
    
    # False negatives (GT only): green
    fn = (ground_truth_resized > 0.5) & (prediction_resized <= 0.5)
    combined_mask_color[fn] = [0, 255, 0]  # Green
    
    combined_overlay = cv2.addWeighted(combined_overlay, 1-alpha, combined_mask_color, alpha, 0)
    
    return gt_overlay, pred_overlay, combined_overlay

def save_visualization(original_image, ground_truth, prediction, dice, iou, 
                       save_path, image_name):
    """Save a comprehensive visualization"""
    # Create overlays
    gt_overlay, pred_overlay, combined_overlay = create_overlay_visualization(
        original_image, ground_truth, prediction
    )
    
    # Create figure
    fig, axes = plt.subplots(2, 3, figsize=(15, 10))
    
    # Row 1: Original, GT, Prediction
    axes[0, 0].imshow(original_image)
    axes[0, 0].set_title('Original Image')
    axes[0, 0].axis('off')
    
    axes[0, 1].imshow(ground_truth, cmap='gray')
    axes[0, 1].set_title('Ground Truth')
    axes[0, 1].axis('off')
    
    axes[0, 2].imshow(prediction, cmap='gray')
    axes[0, 2].set_title('Prediction')
    axes[0, 2].axis('off')
    
    # Row 2: Overlays
    axes[1, 0].imshow(gt_overlay)
    axes[1, 0].set_title('GT Overlay (Green)')
    axes[1, 0].axis('off')
    
    axes[1, 1].imshow(pred_overlay)
    axes[1, 1].set_title('Pred Overlay (Blue)')
    axes[1, 1].axis('off')
    
    axes[1, 2].imshow(combined_overlay)
    axes[1, 2].set_title('Combined\n(Yellow=TP, Red=FP, Green=FN)')
    axes[1, 2].axis('off')
    
    # Add metrics as text
    fig.suptitle(f'{image_name}\nDice: {dice:.4f} | IoU: {iou:.4f}', 
                 fontsize=14, fontweight='bold')
    
    plt.tight_layout()
    plt.savefig(save_path, dpi=150, bbox_inches='tight')
    plt.close()

