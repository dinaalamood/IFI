class ImprovedSolarDataset(Dataset):
    def __init__(self, image_paths, mask_paths, transform=None):
        self.image_paths = image_paths
        self.mask_paths = mask_paths
        self.transform = transform
    
    def __len__(self):
        return len(self.image_paths)
    
    def __getitem__(self, idx):
        # Load image
        img_path = self.image_paths[idx]
        image = cv2.imread(img_path)
        if image is None:
            raise ValueError(f"Could not load image: {img_path}")
        image = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)
        
        # Load mask
        mask_path = self.mask_paths[idx]
        mask = cv2.imread(mask_path, cv2.IMREAD_GRAYSCALE)
        if mask is None:
            raise ValueError(f"Could not load mask: {mask_path}")
        mask = (mask > 127).astype(np.float32)
        
        # Apply transformations
        if self.transform:
            augmented = self.transform(image=image, mask=mask)
            image = augmented['image']
            mask = augmented['mask']
        
        # Add channel dimension to mask
        if len(mask.shape) == 2:
            mask = mask.unsqueeze(0)
        
        return image, mask

def get_moderate_training_augmentation(input_size):
    """Medium augmentation - retains color, moderate geometric transforms"""
    return A.Compose([
        A.Resize(input_size, input_size),
        
        # Geometric transforms (moderate)
        A.HorizontalFlip(p=0.5),
        A.VerticalFlip(p=0.5),
        A.RandomRotate90(p=0.5),
        A.ShiftScaleRotate(
            shift_limit=0.1,
            scale_limit=0.1,
            rotate_limit=15,
            p=0.5
        ),
        
        # Very light color augmentation to preserve original colors
        A.RandomBrightnessContrast(
            brightness_limit=0.1,
            contrast_limit=0.1,
            p=0.3
        ),
        
        # Normalize
        A.Normalize(mean=(0.485, 0.456, 0.406), std=(0.229, 0.224, 0.225)),
        ToTensorV2(),
    ])

def get_validation_augmentation(input_size):
    """Validation augmentation - only resize and normalize"""
    return A.Compose([
        A.Resize(input_size, input_size),
        A.Normalize(mean=(0.485, 0.456, 0.406), std=(0.229, 0.224, 0.225)),
        ToTensorV2(),
    ])

class DecoderBlock(nn.Module):
    """U-Net decoder block with adaptive spatial matching"""
    def __init__(self, in_channels, skip_channels, out_channels):
        super().__init__()
        self.conv1 = nn.Conv2d(in_channels + skip_channels, out_channels, 3, padding=1)
        self.bn1 = nn.BatchNorm2d(out_channels)
        self.conv2 = nn.Conv2d(out_channels, out_channels, 3, padding=1)
        self.bn2 = nn.BatchNorm2d(out_channels)
        self.relu = nn.ReLU(inplace=True)
        
    def forward(self, x, skip=None):
        x = nn.functional.interpolate(x, scale_factor=2, mode='bilinear', align_corners=True)
        
        if skip is not None:
            # Match skip connection size to upsampled features
            if x.shape[2:] != skip.shape[2:]:
                skip = nn.functional.interpolate(skip, size=x.shape[2:], mode='bilinear', align_corners=True)
            x = torch.cat([x, skip], dim=1)
            
        x = self.relu(self.bn1(self.conv1(x)))
        x = self.relu(self.bn2(self.conv2(x)))
        return x

class SwinFeatureExtractor(nn.Module):
    """Wrapper to extract multi-scale features from Swin Transformer"""
    def __init__(self, swin_model):
        super().__init__()
        # Get the actual components from the Swin model
        self.patch_embed = swin_model.patch_embed
        self.layers = swin_model.layers
        
        # These might not exist in all Swin versions
        if hasattr(swin_model, 'pos_drop'):
            self.pos_drop = swin_model.pos_drop
        else:
            self.pos_drop = nn.Identity()
            
        if hasattr(swin_model, 'norm'):
            self.norm = swin_model.norm
        else:
            self.norm = nn.Identity()
        
    def forward(self, x):
        """Extract features from each stage"""
        features = []
        
        # Patch embedding
        x = self.patch_embed(x)
        if hasattr(self, 'pos_drop'):
            x = self.pos_drop(x)
        
        # Go through each Swin stage
        for i, layer in enumerate(self.layers):
            x = layer(x)
            
            # Get the output - x might be (B, H, W, C) or (B, L, C)
            if len(x.shape) == 4:
                # Already in (B, H, W, C) format
                feature = x.permute(0, 3, 1, 2).contiguous()
            else:
                # In (B, L, C) format, need to reshape
                B, L, C = x.shape
                H = W = int(L ** 0.5)
                feature = x.view(B, H, W, C).permute(0, 3, 1, 2).contiguous()
            
            features.append(feature)
        
        return features

class SwinUNet(nn.Module):
    """U-Net with Swin Transformer encoder and custom decoder"""
    def __init__(self, encoder_name='swin_base_patch4_window7_224', 
                 satlas_weights_path=None, num_classes=1):
        super().__init__()
        
        # Create full Swin Transformer model (not features_only)
        full_model = timm.create_model(
            encoder_name,
            pretrained=False,
            num_classes=0  # Remove classification head
        )
        
        # Load Satlas pretrained weights if provided
        if satlas_weights_path and os.path.exists(satlas_weights_path):
            print(f"Loading Satlas pretrained weights from {satlas_weights_path}")
            try:
                state_dict = torch.load(satlas_weights_path, map_location='cpu')
                
                # Handle different checkpoint formats
                if 'model' in state_dict:
                    state_dict = state_dict['model']
                elif 'state_dict' in state_dict:
                    state_dict = state_dict['state_dict']
                
                # Load weights (strict=False to handle partial matches)
                missing, unexpected = full_model.load_state_dict(state_dict, strict=False)
                print(f"Satlas weights loaded! Missing keys: {len(missing)}, Unexpected: {len(unexpected)}")
            except Exception as e:
                print(f"Warning: Could not load Satlas weights: {e}")
                print("Using random initialization")
        else:
            print("Warning: Satlas weights not found, using random initialization")
        
        # Create feature extractor
        self.encoder = SwinFeatureExtractor(full_model)
        
        # Get encoder output channels by running a forward pass
        with torch.no_grad():
            dummy_input = torch.randn(1, 3, 224, 224)
            features = self.encoder(dummy_input)
            encoder_channels = [f.shape[1] for f in features]
            spatial_sizes = [(f.shape[2], f.shape[3]) for f in features]
            print(f"Encoder output channels: {encoder_channels}")
            print(f"Encoder spatial sizes: {spatial_sizes}")
        
        # Verify we got reasonable channels
        if encoder_channels[0] < 100:
            raise ValueError(f"ERROR: Encoder channels are wrong: {encoder_channels}. Expected [128, 256, 512, 1024]")
        
        print(f"✓ Encoder configured correctly with channels: {encoder_channels}")
        
        # Build decoder
        self.decoder4 = DecoderBlock(encoder_channels[3], encoder_channels[2], 512)
        self.decoder3 = DecoderBlock(512, encoder_channels[1], 256)
        self.decoder2 = DecoderBlock(256, encoder_channels[0], 128)
        self.decoder1 = DecoderBlock(128, 0, 64)
        
        # Final segmentation head
        self.segmentation_head = nn.Sequential(
            nn.Conv2d(64, 32, 3, padding=1),
            nn.BatchNorm2d(32),
            nn.ReLU(inplace=True),
            nn.Conv2d(32, num_classes, 1)
        )
    
    def forward(self, x):
        input_size = x.shape[2:]  # Get input H, W
        
        # Encoder
        encoder_features = self.encoder(x)
        
        # Decoder with skip connections
        d4 = self.decoder4(encoder_features[3], encoder_features[2])
        d3 = self.decoder3(d4, encoder_features[1])
        d2 = self.decoder2(d3, encoder_features[0])
        d1 = self.decoder1(d2)
        
        # Upsample to original input size
        d1 = nn.functional.interpolate(d1, size=input_size, mode='bilinear', align_corners=True)
        
        # Segmentation head
        out = self.segmentation_head(d1)
        
        return out

def dice_loss(pred, target, smooth=1e-6):
    """Dice loss for binary segmentation"""
    pred = torch.sigmoid(pred)
    pred = pred.contiguous().view(-1)
    target = target.contiguous().view(-1)
    
    intersection = (pred * target).sum()
    dice = (2. * intersection + smooth) / (pred.sum() + target.sum() + smooth)
    
    return 1 - dice

def combined_loss(pred, target):
    """Combined BCE + Dice loss"""
    bce = nn.BCEWithLogitsLoss()(pred, target)
    dice = dice_loss(pred, target)
    return bce + dice

def dice_coefficient(pred, target, threshold=0.5):
    """Calculate Dice coefficient"""
    pred = torch.sigmoid(pred)
    pred = (pred > threshold).float()
    target = target.float()
    
    intersection = (pred * target).sum()
    union = pred.sum() + target.sum()
    
    dice = (2. * intersection) / (union + 1e-8)
    return dice.item()

def iou_score(pred, target, threshold=0.5):
    """Calculate IoU score"""
    pred = torch.sigmoid(pred)
    pred = (pred > threshold).float()
    target = target.float()
    
    intersection = (pred * target).sum()
    union = pred.sum() + target.sum() - intersection
    
    iou = intersection / (union + 1e-8)
    return iou.item()

def prepare_datasets_three_way_split(config):
    images_dir = Path('/Users/dinaal-amood/amman_satellite_tiles_2020/images')
    masks_dir = Path('/Users/dinaal-amood/Desktop/solar/may 2026/masks')

    # Find images with common extensions
    image_extensions = ["*.png", "*.jpg", "*.jpeg", "*.tif", "*.tiff"]

    image_paths = []
    for ext in image_extensions:
        image_paths.extend(list(images_dir.glob(ext)))

    image_paths = sorted(image_paths)

    print(f"Images folder: {images_dir}")
    print(f"Masks folder:  {masks_dir}")
    print(f"Found {len(image_paths)} images")
    print(f"Found {len(list(masks_dir.glob('*.png')))} masks")

    if len(image_paths) == 0:
        raise ValueError(
            f"No images found in {images_dir}. "
            "Check if the folder path is correct or if images are inside a subfolder."
        )

    valid_pairs = []

    for img in image_paths:
        expected_mask = masks_dir / (img.stem + ".png")

        if expected_mask.exists():
            valid_pairs.append((str(img), str(expected_mask)))

    print(f"Found {len(valid_pairs)} valid image-mask pairs")

    if len(valid_pairs) == 0:
        print("\nSample image filenames:")
        for img in image_paths[:10]:
            print("IMAGE:", img.name)

        print("\nSample mask filenames:")
        for mask in sorted(list(masks_dir.glob('*.png')))[:10]:
            print("MASK:", mask.name)

        raise ValueError(
            "No matching image-mask pairs found. "
            "This means the image filenames and mask filenames do not match."
        )

    image_paths, mask_paths = zip(*valid_pairs)

    train_imgs, val_imgs, train_masks, val_masks = train_test_split(
        list(image_paths),
        list(mask_paths),
        test_size=0.2,
        random_state=config.random_seed
    )

    split_info = {
        "train_images": train_imgs,
        "val_images": val_imgs,
        "train_masks": train_masks,
        "val_masks": val_masks,
        "train_count": len(train_imgs),
        "val_count": len(val_imgs),
        "random_seed": config.random_seed
    }

    os.makedirs(config.save_dir, exist_ok=True)

    with open(config.save_dir / "dataset_split_info.json", "w") as f:
        json.dump(split_info, f, indent=2)

    train_dataset = ImprovedSolarDataset(
        train_imgs,
        train_masks,
        get_moderate_training_augmentation(config.input_size)
    )

    val_dataset = ImprovedSolarDataset(
        val_imgs,
        val_masks,
        get_validation_augmentation(config.input_size)
    )

    test_dataset = None

    print("\nDataset split complete:")
    print(f"Train: {len(train_imgs)}")
    print(f"Val:   {len(val_imgs)}")

    return train_dataset, val_dataset, test_dataset, split_info

def train_epoch(model, dataloader, criterion, optimizer, device):
    """Train for one epoch"""
    model.train()
    running_loss = 0.0
    running_dice = 0.0
    running_iou = 0.0
    
    pbar = tqdm(dataloader, desc="Training")
    for images, masks in pbar:
        images = images.to(device)
        masks = masks.to(device)
        
        optimizer.zero_grad()
        outputs = model(images)
        loss = criterion(outputs, masks)
        
        loss.backward()
        optimizer.step()
        
        running_loss += loss.item()
        running_dice += dice_coefficient(outputs, masks)
        running_iou += iou_score(outputs, masks)
        
        pbar.set_postfix({
            'loss': f'{loss.item():.4f}',
            'dice': f'{dice_coefficient(outputs, masks):.4f}'
        })
    
    epoch_loss = running_loss / len(dataloader)
    epoch_dice = running_dice / len(dataloader)
    epoch_iou = running_iou / len(dataloader)
    
    return epoch_loss, epoch_dice, epoch_iou

def validate(model, dataloader, criterion, device):
    """Validate the model"""
    model.eval()
    running_loss = 0.0
    running_dice = 0.0
    running_iou = 0.0
    
    with torch.no_grad():
        for images, masks in tqdm(dataloader, desc="Validation"):
            images = images.to(device)
            masks = masks.to(device)
            
            outputs = model(images)
            loss = criterion(outputs, masks)
            
            running_loss += loss.item()
            running_dice += dice_coefficient(outputs, masks)
            running_iou += iou_score(outputs, masks)
    
    epoch_loss = running_loss / len(dataloader)
    epoch_dice = running_dice / len(dataloader)
    epoch_iou = running_iou / len(dataloader)
    
    return epoch_loss, epoch_dice, epoch_iou

def train(config):
    """Main training function"""
    
    # Set random seed
    torch.manual_seed(config.random_seed)
    np.random.seed(config.random_seed)
    
    # Prepare datasets
    train_dataset, val_dataset, test_dataset, split_info = prepare_datasets_three_way_split(config)
    
    train_loader = DataLoader(
        train_dataset,
        batch_size=config.batch_size,
        shuffle=True,
        num_workers=0
    )
    
    val_loader = DataLoader(
        val_dataset,
        batch_size=config.batch_size,
        shuffle=False,
        num_workers=0
    )
    
    # Create model with Satlas weights
    print("\nInitializing Swin Transformer U-Net with Satlas pretrained weights...")
    model = SwinUNet(
        encoder_name=config.encoder_name,
        satlas_weights_path=config.satlas_weights_path,
        num_classes=config.num_classes
    )
    model = model.to(config.device)
    
    # Count parameters
    total_params = sum(p.numel() for p in model.parameters())
    print(f"Total parameters: {total_params:,}")
    
    # Loss and optimizer
    criterion = combined_loss
    optimizer = optim.AdamW(
        model.parameters(),
        lr=config.learning_rate,
        weight_decay=config.weight_decay
    )
    
    # Learning rate scheduler
    scheduler = optim.lr_scheduler.ReduceLROnPlateau(
        optimizer,
        mode='max',
        factor=0.5,
        patience=5
    )
    
    # Training tracking
    best_dice = 0.0
    patience_counter = 0
    history = {
        'train_loss': [], 'train_dice': [], 'train_iou': [],
        'val_loss': [], 'val_dice': [], 'val_iou': []
    }
    
    print(f"\nStarting training for {config.num_epochs} epochs...")
    print(f"Device: {config.device}")
    print(f"Input size: ({config.input_size}, {config.input_size})")
    print(f"Classes: {config.num_classes}")
    print(f"Using Satlas Aerial_SwinB_SI pretrained weights\n")
    
    for epoch in range(config.num_epochs):
        print(f"\nEpoch {epoch+1}/{config.num_epochs}")
        print(f"LR: {optimizer.param_groups[0]['lr']:.6f}")
        
        # Train
        train_loss, train_dice, train_iou = train_epoch(
            model, train_loader, criterion, optimizer, config.device
        )
        
        # Validate
        val_loss, val_dice, val_iou = validate(
            model, val_loader, criterion, config.device
        )
        
        # Update scheduler
        scheduler.step(val_dice)
        
        # Save history
        history['train_loss'].append(train_loss)
        history['train_dice'].append(train_dice)
        history['train_iou'].append(train_iou)
        history['val_loss'].append(val_loss)
        history['val_dice'].append(val_dice)
        history['val_iou'].append(val_iou)
        
        # Print metrics
        print(f"Train - Loss: {train_loss:.4f}, Dice: {train_dice:.4f}, IoU: {train_iou:.4f}")
        print(f"Val   - Loss: {val_loss:.4f}, Dice: {val_dice:.4f}, IoU: {val_iou:.4f}")
        
        # Save best model
        if val_dice > best_dice + config.min_delta:
            best_dice = val_dice
            patience_counter = 0
            
            torch.save({
                'epoch': epoch,
                'model_state_dict': model.state_dict(),
                'optimizer_state_dict': optimizer.state_dict(),
                'scheduler_state_dict': scheduler.state_dict(),
                'val_dice': val_dice,
                'val_iou': val_iou,
                'config': vars(config)
            }, config.save_dir / 'best_modelswine.pth')
            
            print(f"💾 New best model saved! Dice: {best_dice:.4f}, IoU: {val_iou:.4f}")
        else:
            patience_counter += 1
            print(f"No improvement ({patience_counter}/{config.patience})")
        
        # Early stopping
        if patience_counter >= config.patience:
            print(f"\nEarly stopping triggered after {epoch+1} epochs")
            break
    
    # Save training history
    np.save(config.save_dir / 'training_history.npy', history)
    
    # Plot training curves
    plot_training_curves(history, config.save_dir)
    
    print(f"\nTraining complete!")
    print(f"Best validation Dice: {best_dice:.4f}")
    print(f"Model saved to: {config.save_dir / 'best_modelswine.pth'}")

def plot_training_curves(history, save_dir):
    """Plot and save training curves"""
    fig, axes = plt.subplots(1, 3, figsize=(18, 5))
    
    # Loss
    axes[0].plot(history['train_loss'], label='Train')
    axes[0].plot(history['val_loss'], label='Val')
    axes[0].set_title('Loss')
    axes[0].set_xlabel('Epoch')
    axes[0].legend()
    
    # Dice
    axes[1].plot(history['train_dice'], label='Train')
    axes[1].plot(history['val_dice'], label='Val')
    axes[1].set_title('Dice Score')
    axes[1].set_xlabel('Epoch')
    axes[1].legend()
    
    # IoU
    axes[2].plot(history['train_iou'], label='Train')
    axes[2].plot(history['val_iou'], label='Val')
    axes[2].set_title('IoU Score')
    axes[2].set_xlabel('Epoch')
    axes[2].legend()
    
    plt.tight_layout()
    plt.savefig(save_dir / 'training_curves.png', dpi=150, bbox_inches='tight')
    plt.close()

if __name__ == "__main__":
    config = Config()
    train(config)
